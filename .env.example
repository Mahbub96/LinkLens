# ─── Database ───
DATABASE_URL="postgresql://linklens:linklens_secret@localhost:5433/linklens?schema=public"

# ─── Redis ───
REDIS_URL="redis://localhost:6379"

# ─── ClickHouse ───
CLICKHOUSE_URL="http://localhost:8123"
CLICKHOUSE_DB="linklens"

# ─── JWT ───
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ───
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
PORT=4000
NODE_ENV="development"

# ─── Caddy ───
CADDY_ADMIN_URL="http://localhost:2019"

# ─── MaxMind (optional – place .mmdb in backend/data/) ───
MAXMIND_DB_PATH="./data/GeoLite2-City.mmdb"
